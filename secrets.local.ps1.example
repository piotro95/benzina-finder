# =====================================================================
# secrets.local.ps1.example
# =====================================================================
# Copia questo file in "secrets.local.ps1" (stesso percorso) e
# riempi i valori reali. "secrets.local.ps1" è in .gitignore: resta
# SOLO sul tuo PC, non viene mai versionato né pushato su GitHub.
#
#   Copy-Item secrets.local.ps1.example secrets.local.ps1
#   notepad secrets.local.ps1
# =====================================================================

# Percorso completo dell'eseguibile Python (quello già usato in CI)
$env:PYTHON_EXE = "C:\Users\PietroRomei\AppData\Local\Programs\Python\Python311\python.exe"

# Posizione di partenza (coordinate reali — restano solo qui, in locale)
$env:START_LAT  = "0.0"
$env:START_LON  = "0.0"
$env:START_NOME = "Casa"

# Credenziali bot Telegram
$env:TG_TOKEN   = "INSERISCI_IL_TOKEN_DEL_BOT"
$env:TG_CHAT_ID = "INSERISCI_IL_CHAT_ID"
